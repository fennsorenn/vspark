# Copy to .env and fill in. See README.md.

# Public DNS name pointing at this host (Caddy gets a TLS cert for it; also the
# coturn realm). Collaborators use wss://RDV_DOMAIN as their rendezvous URL.
RDV_DOMAIN=rdv.example.com

# This host's PUBLIC IP (coturn advertises it as the relay address).
PUBLIC_IP=203.0.113.10

# Shared secret between the rendezvous and coturn for short-lived TURN creds.
# Generate: openssl rand -hex 32
TURN_SECRET=replace-me-with-a-long-random-secret

# TURN URLs handed to peers (comma-separated). Use your RDV_DOMAIN or PUBLIC_IP.
TURN_URLS=turn:rdv.example.com:3478

# STUN URLs (comma-separated). A public STUN is fine; coturn also serves STUN.
STUN_URLS=stun:rdv.example.com:3478,stun:stun.l.google.com:19302

# TURN resource caps (container limits; relay throughput caps live in
# coturn/turnserver.conf).
TURN_CPU_LIMIT=1.0
TURN_MEM_LIMIT=256M
