{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@vspark/shared": ["../shared/src/types.ts"],
      "@vspark/shared/types": ["../shared/src/types.ts"],
      "@vspark/shared/schema": ["../shared/src/schema.ts"],
      "@vspark/shared/signal": ["../shared/src/signal.ts"],
      "@vspark/shared/arkit": ["../shared/src/arkit_tables.ts"]
    }
  },
  "include": ["src"]
}
